# Copy this file to .env (for local overrides) or set this variable
# directly in your hosting platform's dashboard (e.g. Vercel) for deployment.
#
# LOCAL DEV: leave unset -- api.js falls back to http://localhost:8000
#            automatically, so you don't need a .env file at all for
#            running this on your own machine.
#
# DEPLOYMENT: set this to your deployed backend's URL, e.g.
VITE_API_BASE_URL=https://parkpulse-production.up.railway.app